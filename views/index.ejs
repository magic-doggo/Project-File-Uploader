<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Index</title>
</head>

<body>
    <%- include("partials/navbar") %>
        <div>
            <h2>Create a new Post</h2>
            <% if (!locals.user) {%>
                <div>You are not logged in. Please <a href="/sign-in">log in</a> to upload a file, or review your
                    current files!</div>
                <% } else { %>
                    <form action="/upload" method="post" enctype="multipart/form-data">
                        <label for="files">Choose files to upload</label>
                        <input type="file" id="files" name="files" multiple />
                        <button type="submit">Submit</button>
                    </form>

                    <!-- <form action="createNewFolder" method="post">
                        <input type="text" id="folder" name="folder" placeholder="folder name" />
                        <button type="submit">Create folder</button>
                    </form> -->
                    <% } %>



        </div>
        <script>

        </script>
</body>

</html>